# pj 서버 환경변수 템플릿
# 이 파일을 local.env 로 복사하고 값 채워 사용
#   cp local.env.example local.env
# app.py 부팅 시 local.env 가 있으면 자동 로드됨

# ── 서버 ──
PJ_PORT=7860

# ── Ollama 추론 ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# 어려운 자료에 대해 고급 추론이 필요할 때 32B 로 전환 가능
# OLLAMA_MODEL=qwen3:32b

# ── 원격 LLM (학교 GPU 서버 분리해서 쓸 때 활성화) ──
# REMOTE_LLM_URL=http://100.118.126.123:11434
# REMOTE_LLM_MODEL=exaone3.5:32b

# ── 인증 ──
# 운영 시 반드시 변경 — 32자 이상 랜덤 권장
SECRET_KEY=woosong-ai-tutor-secret-change-me
TOKEN_EXPIRE_HOURS=24

# ── 데이터 ──
# RAG_INDEX_DIR=rag_indexes
# DB_PATH=students.db

# ── OCR ──
# Surya 장치 — cuda 사용 가능하면 cuda
SURYA_DEVICE=cpu
